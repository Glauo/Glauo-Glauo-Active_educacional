# ═══════════════════════════════════════════════════════════
# ATIVO EDUCACIONAL — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ═══════════════════════════════════════════════════════════

# Banco de dados PostgreSQL (mesma URL usada no Streamlit)
ACTIVE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Segredo JWT (gere uma string aleatória longa)
JWT_SECRET=troque-por-uma-string-aleatoria-segura-2026

# Ambiente
NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# MERCADO PAGO — Boleto Bancário
# Obtenha em: https://www.mercadopago.com.br/developers
# ═══════════════════════════════════════════════════════════

# Access Token (obrigatorio para gerar boletos reais)
MP_ACCESS_TOKEN=APP_USR-4713753450558393-052911-fe06bce27704ad491468ea178b863b04-3424597237

