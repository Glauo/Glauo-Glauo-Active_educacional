# ═══════════════════════════════════════════════════════════
# ATIVO EDUCACIONAL — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ═══════════════════════════════════════════════════════════

# Banco de dados PostgreSQL (mesma URL usada no Streamlit)
ACTIVE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Segredo JWT (gere uma string aleatória longa)
JWT_SECRET=troque-por-uma-string-aleatoria-segura-2026

# Ambiente
NODE_ENV=development
