# ═══════════════════════════════════════════════════════════
# ATIVO EDUCACIONAL — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ═══════════════════════════════════════════════════════════

# Banco de dados PostgreSQL
ACTIVE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Segredo JWT (gere uma string aleatória longa)
JWT_SECRET=troque-por-uma-string-aleatoria-segura-2026

# Ambiente
NODE_ENV=development

# Wiz IA
GROQ_API_KEY=
ACTIVE_GROQ_API_KEY=
ACTIVE_WIZ_MODEL=llama-3.3-70b-versatile
ACTIVE_HOMEWORK_GRADER_MODEL=llama-3.3-70b-versatile

# Mercado Pago boleto
ACTIVE_MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_ACCESS_TOKEN=
ACTIVE_MERCADO_PAGO_WEBHOOK_URL=
ACTIVE_MERCADO_PAGO_WEBHOOK_SECRET=
